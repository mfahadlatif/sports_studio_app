# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcconfig}."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

      # Fix for Xcode 15+ resource sandbox issues
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'

      # Fix for Apple Silicon Macs: only exclude i386, not arm64.
      # The simulator on Apple Silicon IS arm64, so don't exclude it.
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386'

      # FIX for libswiftWebKit.dylib crash on iOS 18.5+ simulator:
      # flutter_inappwebview_ios links against Swift WebKit APIs. On modern simulators
      # the Swift dylibs are not at /usr/lib/swift anymore. Embedding them in the .app
      # bundle makes the app self-contained and resolves the "Library not loaded" crash.
      config.build_settings['ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES'] = 'YES'

      # FIX for "Build input file cannot be found: GoogleMapsResources.bundle":
      # GoogleMaps 9.x+ generates resource bundles via a script phase.
      if target.name.include?('GoogleMaps')
        config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
        config.build_settings['DEFINES_MODULE'] = 'YES'
      end
    end
  end

  # FINAL ROBUST FIX for "Build input file cannot be found" errors:
  # Pre-create all known problematic resource bundles and their internal files.
  project_root = File.expand_path('../..', __FILE__)
  ['Debug', 'Release', 'Profile'].each do |config|
    config_dir = "#{config}-iphonesimulator"
    
    # Map of [Target Directory] => [Array of Bundle Names]
    bundles = {
      'GoogleMaps' => ['GoogleMapsResources.bundle'],
      'flutter_local_notifications' => ['flutter_local_notifications_privacy.bundle'],
      'geocoding_ios' => ['geocoding_ios_privacy.bundle'],
      'url_launcher_ios' => ['url_launcher_ios_privacy.bundle'],
      'sqflite_darwin' => ['sqflite_darwin_privacy.bundle'],
      'shared_preferences_foundation' => ['shared_preferences_foundation_privacy.bundle'],
      'path_provider_foundation' => ['path_provider_foundation_privacy.bundle'],
      'package_info_plus' => ['package_info_plus_privacy.bundle'],
      'nanopb' => ['nanopb_Privacy.bundle'],
      'image_picker_ios' => ['image_picker_ios_privacy.bundle'],
      'geolocator_apple' => ['geolocator_apple_privacy.bundle'],
      'flutter_secure_storage_darwin' => ['flutter_secure_storage.bundle'],
      'PromisesObjC' => ['FBLPromises_Privacy.bundle'],
      'GoogleUtilities' => ['GoogleUtilities_Privacy.bundle'],
      'AppAuth' => ['AppAuth_Privacy.bundle', 'AppAuthCore_Privacy.bundle'],
      'OrderedSet' => ['OrderedSet_privacy.bundle'],
      'GTMSessionFetcher' => ['GTMSessionFetcher_Core_Privacy.bundle', 'GTMSessionFetcher_Full_Privacy.bundle'],
      'firebase_messaging' => ['firebase_messaging_Privacy.bundle'],
      'google_maps_flutter_ios' => ['google_maps_flutter_ios_privacy.bundle'],
      'google_sign_in_ios' => ['google_sign_in_ios_privacy.bundle'],
      'flutter_inappwebview_ios' => ['flutter_inappwebview_ios_privacy.bundle'],
      'sign_in_with_apple' => ['sign_in_with_apple_privacy.bundle'],
      'GoogleSignIn' => ['GoogleSignIn.bundle'],
      'AppCheckCore' => ['AppCheckCore_Privacy.bundle'],
      'GTMAppAuth' => ['GTMAppAuth_Privacy.bundle'],
      'FirebaseCore' => ['FirebaseCore_Privacy.bundle'],
      'FirebaseCoreInternal' => ['FirebaseCoreInternal_Privacy.bundle'],
      'FirebaseMessaging' => ['FirebaseMessaging_Privacy.bundle'],
      'FirebaseAppCheckInterop' => ['FirebaseAppCheckInterop_Privacy.bundle'],
      'GoogleDataTransport' => ['GoogleDataTransport_Privacy.bundle'],
      'FirebaseAuth' => ['FirebaseAuth_Privacy.bundle'],
      'FirebaseCoreExtension' => ['FirebaseCoreExtension_Privacy.bundle'],
      'FirebaseInstallations' => ['FirebaseInstallations_Privacy.bundle']
    }
    
    bundles.each do |target, bundle_names|
      bundle_names.each do |bundle_name|
        bundle_path = File.join(project_root, 'build', 'ios', config_dir, target, bundle_name)
        FileUtils.mkdir_p(bundle_path)
        
        # The binary name is usually the same as the bundle name without .bundle
        binary_name = bundle_name.gsub('.bundle', '')
        resource_file = File.join(bundle_path, binary_name)
        
        unless File.exist?(resource_file)
          puts "Creating dummy resource: #{resource_file}"
          FileUtils.touch(resource_file)
        end
      end
    end
  end
end
